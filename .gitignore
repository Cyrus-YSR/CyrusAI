yarn-debug.log*
yarn-error.log*
vue-frontend/node_modules/
vue-frontend/dist/

# IDEs
.idea/
.vscode/
*.swp
*.swo

# OS specific
.DS_Store
Thumbs.db

# Project specific
logs/
tmp/
uploads/
